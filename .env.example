# Kopieren nach `.env.local` für lokale Entwicklung:
#   cp .env.example .env.local
# Werte aus dem EmailJS-Dashboard (gleicher Service / Public Key für alle Templates).
#
# Optional (Server-Alias, gleiche Werte wie oben): falls NEXT_PUBLIC_* im Build mal leer ist
# EMAILJS_SERVICE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_TEMPLATE_ID_LEAD=
# EMAILJS_TEMPLATE_ID_BEWERBUNG=

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Kontakt / Schnellanfrage (HeroForm, ContactForm)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# Bewerbungsformular (Jobs) — separates Template mit denselben Platzhaltern wie die `name`-Felder im Formular.
# PDF-Anhang: Im Template unter „Attachments“ → „Form File Attachment“, Parametername exakt: bewerbung_anhang
NEXT_PUBLIC_EMAILJS_BEWERBUNG_TEMPLATE_ID=
